{
  "expo": {
    "name": "Coco",
    "slug": "coco",
    "scheme": "coco",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "primaryColor": "#0E8A5F",
    "description": "A quiet companion for your mind. Mood, journal, breathing, sleep, daily check-ins, an AI listener, and a directory of crisis resources — all in one calm app.",
    "githubUrl": "https://github.com/rodriguescarson/coco2",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F8F5EE",
      "dark": {
        "image": "./assets/splash-icon.png",
        "resizeMode": "contain",
        "backgroundColor": "#08120E"
      }
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.rodriguescarson.coco",
      "buildNumber": "1",
      "icon": "./assets/icon.png",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSMicrophoneUsageDescription": "Coco can listen for anonymous voice journaling sessions when you start one.",
        "NSUserTrackingUsageDescription": "Coco never tracks you across apps. This permission is unused unless you opt in to contribute anonymized research data."
      },
      "config": {
        "usesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.rodriguescarson.coco",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0E8A5F"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "INTERNET",
        "VIBRATE",
        "ACCESS_NETWORK_STATE"
      ]
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png",
      "name": "Coco",
      "shortName": "Coco",
      "themeColor": "#0E8A5F",
      "backgroundColor": "#F8F5EE",
      "display": "standalone"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "imageWidth": 220,
          "resizeMode": "contain",
          "backgroundColor": "#F8F5EE",
          "dark": {
            "image": "./assets/splash-icon.png",
            "imageWidth": 220,
            "resizeMode": "contain",
            "backgroundColor": "#08120E"
          }
        }
      ],
      "expo-audio"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "apiBaseUrl": "https://coco-api-nine.vercel.app",
      "firebase": {
        "apiKey": "AIzaSyBM4cN4aGimCCRrDosTpdJykQohOJKXmVA",
        "authDomain": "coco-sih.firebaseapp.com",
        "projectId": "coco-sih",
        "storageBucket": "coco-sih.appspot.com",
        "messagingSenderId": "522896815441",
        "appId": "1:522896815441:web:6e29e18ad700b390a8cf70",
        "measurementId": "G-PZMPYC9YTE"
      },
      "googleClientIdWeb": "522896815441-s2bvu8ng4kc4qvpulrcu7au1bia33d2e.apps.googleusercontent.com",
      "googleClientIdIos": "REPLACE_WITH_IOS_OAUTH_CLIENT_ID.apps.googleusercontent.com",
      "googleClientIdAndroid": "REPLACE_WITH_ANDROID_OAUTH_CLIENT_ID.apps.googleusercontent.com"
    }
  }
}
