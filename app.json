{
  "expo": {
    "name": "Coco",
    "slug": "coco",
    "scheme": "coco",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F4F0EA"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.rodriguescarson.coco",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.rodriguescarson.coco",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#F4F0EA"
      },
      "edgeToEdgeEnabled": true
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#F4F0EA",
          "dark": {
            "backgroundColor": "#0F1814"
          }
        }
      ],
      "expo-audio"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "apiBaseUrl": "https://coco-api-nine.vercel.app",
      "firebase": {
        "apiKey": "AIzaSyBM4cN4aGimCCRrDosTpdJykQohOJKXmVA",
        "authDomain": "coco-sih.firebaseapp.com",
        "projectId": "coco-sih",
        "storageBucket": "coco-sih.appspot.com",
        "messagingSenderId": "522896815441",
        "appId": "1:522896815441:web:6e29e18ad700b390a8cf70",
        "measurementId": "G-PZMPYC9YTE"
      },
      "googleClientIdWeb": "522896815441-s2bvu8ng4kc4qvpulrcu7au1bia33d2e.apps.googleusercontent.com"
    }
  }
}
