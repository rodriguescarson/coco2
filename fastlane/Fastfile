# Coco store submission via fastlane.
#
# This repo builds AND uploads with fastlane (no EAS). Native projects are
# generated by `npx expo prebuild --clean`; the lanes below compile a signed
# artifact and ship it.
#
# Run from the project root (/Users/carson/Projects/coco):
#   fastlane ios release         # build signed .ipa -> TestFlight
#   fastlane android release     # build signed .aab -> Play internal track
#   fastlane ios build           # build .ipa only (-> ./build/coco.ipa)
#   fastlane android build       # build .aab only (-> ./build/coco.aab)
#   fastlane ios beta            # upload existing ./build/coco.ipa
#   fastlane android internal    # upload existing ./build/coco.aab
#
# Signing:
#   iOS     — automatic, via the App Store Connect API key (.p8). Xcode
#             provisions the distribution cert + App Store profile on demand.
#   Android — the coco-dev upload keystore, wired through android/gradle.properties
#             (COCO_* props) into app/build.gradle's release signingConfig.
#
# Build numbers are derived from the stores (latest + 1) so re-runs never
# collide with an already-uploaded build.

ROOT      = File.expand_path("..", __dir__)
IPA_PATH  = File.join(ROOT, "build", "coco.ipa")
AAB_PATH  = File.join(ROOT, "build", "coco.aab")
ASC_P8    = File.join(ROOT, "credentials", "AuthKey_95P9D8959L.p8")

ASC_KEY_ID    = "95P9D8959L"
ASC_ISSUER_ID = "3a0248cc-5c1d-4eeb-813d-82e19a9cf785"
PACKAGE_NAME  = "com.rodriguescarson.coco"
APP_VERSION   = "1.0.0"

IOS_PROJECT   = File.join(ROOT, "ios", "Coco.xcodeproj")
IOS_WORKSPACE = File.join(ROOT, "ios", "Coco.xcworkspace")
IOS_SCHEME    = "Coco"
TEAM_ID       = "AT45DRFG4P"

GRADLE_FILE   = File.join(ROOT, "android", "app", "build.gradle")

def asc_api_key
  app_store_connect_api_key(
    key_id: ASC_KEY_ID,
    issuer_id: ASC_ISSUER_ID,
    key_filepath: ASC_P8,
    in_house: false,
  )
end

platform :ios do
  desc "Build a signed App Store .ipa (-> ./build/coco.ipa)"
  lane :build do
    api_key = asc_api_key

    # One above the latest build already on TestFlight for this version.
    latest = latest_testflight_build_number(
      api_key: api_key,
      app_identifier: PACKAGE_NAME,
      version: APP_VERSION,
      initial_build_number: 0,
    )
    # CFBundleVersion is a literal in the Expo-generated Info.plist, so set it
    # directly — avoids agvtool/Apple-Generic versioning (not enabled here).
    set_info_plist_value(
      path: File.join(ROOT, "ios", "Coco", "Info.plist"),
      key: "CFBundleVersion",
      value: (latest + 1).to_s,
    )

    update_code_signing_settings(
      use_automatic_signing: true,
      team_id: TEAM_ID,
      path: IOS_PROJECT,
    )

    build_app(
      workspace: IOS_WORKSPACE,
      scheme: IOS_SCHEME,
      configuration: "Release",
      export_method: "app-store",
      output_directory: File.join(ROOT, "build"),
      output_name: "coco.ipa",
      clean: true,
      export_options: { signingStyle: "automatic" },
      # Let Xcode mint/refresh the distribution cert + profile using the API key.
      xcargs: "-allowProvisioningUpdates " \
              "-authenticationKeyPath #{ASC_P8} " \
              "-authenticationKeyID #{ASC_KEY_ID} " \
              "-authenticationKeyIssuerID #{ASC_ISSUER_ID}",
    )
  end

  desc "Upload the existing build/coco.ipa to TestFlight"
  lane :beta do
    UI.user_error!("Missing #{IPA_PATH} — run `fastlane ios build` first") unless File.exist?(IPA_PATH)
    upload_to_testflight(
      api_key: asc_api_key,
      ipa: IPA_PATH,
      skip_submission: true,                       # land in TestFlight, don't auto-submit for review
      skip_waiting_for_build_processing: true,     # don't block on Apple's processing queue
    )
  end

  desc "Build a signed .ipa and upload it to TestFlight"
  lane :release do
    build
    beta
  end
end

platform :android do
  desc "Build a signed release .aab (-> ./build/coco.aab)"
  lane :build do
    # One above the highest versionCode across Play tracks for this app.
    codes = %w[internal alpha beta production].flat_map do |track|
      begin
        google_play_track_version_codes(
          package_name: PACKAGE_NAME,
          json_key: File.join(ROOT, "credentials", "service-account-key.json"),
          track: track,
        )
      rescue StandardError
        []
      end
    end
    next_code = (codes.flatten.map(&:to_i).max || 0) + 1
    UI.message("Using Android versionCode #{next_code}")

    # build.gradle hard-codes `versionCode N`; rewrite it for this build.
    gradle = File.read(GRADLE_FILE)
    gradle = gradle.sub(/versionCode\s+\d+/, "versionCode #{next_code}")
    File.write(GRADLE_FILE, gradle)

    # NB: don't use `gradle clean` — it triggers externalNativeBuildClean, which
    # re-runs CMake configure on the native modules and flakes on a stale .cxx
    # cache. Wipe the build + CMake dirs directly for a clean release instead.
    FileUtils.rm_rf(File.join(ROOT, "android", "app", "build"))
    FileUtils.rm_rf(File.join(ROOT, "android", "app", ".cxx"))
    gradle(
      task: "bundle",
      build_type: "Release",
      project_dir: File.join(ROOT, "android"),
    )

    FileUtils.mkdir_p(File.join(ROOT, "build"))
    FileUtils.cp(lane_context[SharedValues::GRADLE_AAB_OUTPUT_PATH], AAB_PATH)
    UI.success("Wrote #{AAB_PATH}")
  end

  desc "Upload the existing build/coco.aab to the Play internal track"
  lane :internal do
    UI.user_error!("Missing #{AAB_PATH} — run `fastlane android build` first") unless File.exist?(AAB_PATH)
    upload_to_play_store(
      package_name: PACKAGE_NAME,
      json_key: File.join(ROOT, "credentials", "service-account-key.json"),
      aab: AAB_PATH,
      track: "internal",
      release_status: "completed",
      skip_upload_apk: true,
      skip_upload_metadata: true,
      skip_upload_changelogs: true,
      skip_upload_images: true,
      skip_upload_screenshots: true,
    )
  end

  desc "Build a signed .aab and upload it to the Play internal track"
  lane :release do
    build
    internal
  end
end
