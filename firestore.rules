rules_version = '2';

// Coco Firestore security rules.
//
// 1. Private user data lives under /users/{uid}/** — only that user can touch it.
// 2. Community peer-support content lives in shared top-level collections:
//      /posts/{postId}     — anonymous, moderated circle posts
//      /reports/{reportId} — abuse reports (write-only moderation queue)
//    Posts are readable by any signed-in user; the client hides removed,
//    heavily-reported, and blocked-author posts. Server-side moderation runs
//    before a post is created (see api/moderate.ts) and human review acts on
//    the /reports queue.
service cloud.firestore {
  match /databases/{database}/documents {

    // Moderators. Add your Firebase Auth UID here to read the /reports queue
    // and remove posts from the in-app Moderation screen (which shows your UID).
    // Empty by default → admin powers are dormant until you opt in.
    function isAdmin() {
      return request.auth != null && request.auth.uid in [
        'qnp4TAZYyDZgpCtZHTnoOVM12NT2', // Carson (rodriguescarson@gmail.com)
      ];
    }

    // --- Private, per-user data -------------------------------------------
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;

      // Push notification tokens. Coco has NO Cloud Functions / server, so the
      // client-side sendExpoPush() helper must read a *recipient's* tokens to
      // deliver a nudge. We therefore let any signed-in user READ tokens, while
      // only the owner may write/delete their own. Tokens are opaque Expo
      // delivery handles — they carry no mood/journal/crisis or personal data.
      //
      // INTEGRITY TRADEOFF: this means a signed-in user who knows another uid
      // could enqueue an Expo push to them. That is acceptable only for
      // low-stakes, non-sensitive nudges. If abuse becomes a concern, move
      // sending behind a trusted server (see Amorelle's push-send function) and
      // tighten this back to owner-only.
      match /pushTokens/{token} {
        allow read: if request.auth != null;
        allow write: if request.auth != null && request.auth.uid == uid;
      }

      match /{collection}/{docId=**} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
    }

    // --- Shared community posts -------------------------------------------
    match /posts/{postId} {
      // Any signed-in user can read the feed.
      allow read: if request.auth != null;

      // A user may only create a post authored by themselves, with a sane,
      // length-bounded body and the safety fields initialised.
      allow create: if request.auth != null
        && request.resource.data.authorUid == request.auth.uid
        && request.resource.data.circleId is string
        && request.resource.data.circleId.size() <= 64
        && request.resource.data.body is string
        && request.resource.data.body.size() > 0
        && request.resource.data.body.size() <= 1000
        && request.resource.data.authorHandle is string
        && request.resource.data.authorHandle.size() <= 40
        && request.resource.data.reportCount == 0
        && request.resource.data.removed == false;

      // Reporting: any signed-in user may bump reportCount by exactly one, and
      // may not touch the body, author, circle, or removed flag.
      allow update: if request.auth != null
        && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['reportCount', 'updatedAt'])
        && request.resource.data.reportCount == resource.data.reportCount + 1
        && request.resource.data.removed == resource.data.removed
        && request.resource.data.authorUid == resource.data.authorUid
        && request.resource.data.body == resource.data.body
        && request.resource.data.circleId == resource.data.circleId;

      // Removal: only the author or a moderator may hide a post.
      allow update: if (isAdmin() || resource.data.authorUid == request.auth.uid)
        && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['removed', 'updatedAt']);

      // Authors and moderators can hard-delete.
      allow delete: if request.auth != null
        && (isAdmin() || resource.data.authorUid == request.auth.uid);
    }

    // --- Referral / invite loop -------------------------------------------
    // referralCodes: a public (signed-in readable) lookup table mapping a short
    // code → the owner's uid, so a friend can resolve a code without reading the
    // owner's private /users doc. Each user reserves their own code once; codes
    // are immutable so they can never be re-pointed at someone else.
    match /referralCodes/{code} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.keys().hasOnly(['uid', 'createdAt']);
      allow update, delete: if false;
    }

    // referrals: one immutable doc per (referrer, referred) pair. The doc id is
    // deterministic ("<referrerId>_<referredId>") so a pair can't be claimed
    // twice. A user may only create a referral where THEY are the referred
    // party, can't refer themselves, and the referrer must be a real account.
    // No mood/journal/clinical data ever lives here — only the two uids + a ts.
    match /referrals/{pairId} {
      allow read: if request.auth != null
        && (resource.data.referrerId == request.auth.uid
            || resource.data.referredId == request.auth.uid);
      allow create: if request.auth != null
        && request.resource.data.referredId == request.auth.uid
        && request.resource.data.referrerId is string
        && request.resource.data.referrerId != request.auth.uid
        && pairId == request.resource.data.referrerId + '_' + request.resource.data.referredId
        && request.resource.data.keys().hasOnly(['referrerId', 'referredId', 'createdAt'])
        && exists(/databases/$(database)/documents/users/$(request.resource.data.referrerId));
      allow update, delete: if false;
    }

    // --- Abuse reports ----------------------------------------------------
    match /reports/{reportId} {
      allow create: if request.auth != null
        && request.resource.data.reporterUid == request.auth.uid
        && request.resource.data.postId is string
        && request.resource.data.reason is string
        && request.resource.data.reason.size() <= 200;
      // Moderators read the queue (in-app screen / console) and clear it.
      allow read, delete: if isAdmin();
      allow update: if false;
    }
  }
}
